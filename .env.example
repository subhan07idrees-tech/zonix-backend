# ZONIX Backend Environment Configuration
# Copy this file to .env and update the values

# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/zonix?schema=public"

# JWT Authentication
JWT_SECRET="change-this-to-a-strong-random-secret-in-production"
JWT_EXPIRY="24h"

# Cookie Encryption Key (must be exactly 32 characters)
COOKIE_ENCRYPTION_KEY="zonix-cookie-key-change-in-production-32ch"

# CORS
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# Electron Client
ZONIX_BACKEND_URL="https://localhost:4000"
ZONIX_WS_URL="wss://localhost:4000/ws"
